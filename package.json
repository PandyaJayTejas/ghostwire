{
  "name": "ghostwire",
  "version": "0.1.0",
  "description": "Peer-to-peer local network communication — no internet required",
  "main": "src/main/index.js",
  "scripts": {
    "dev:vite": "vite --port 5173",
    "dev:electron": "node scripts/start-electron.js",
    "dev": "concurrently -k -n vite,electron -c cyan,green \"npm run dev:vite\" \"npm run dev:electron\"",
    "build": "vite build",
    "start": "electron .",
    "test": "node --test test/"
  },
  "keywords": ["p2p", "mesh", "bluetooth", "wifi", "offline", "chat"],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.1",
    "qrcode": "^1.5.4"
  }
}
